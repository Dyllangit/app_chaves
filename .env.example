# Copie este arquivo para .env e preencha os valores

# Servidor
PORT=3000
NODE_ENV=development

# Banco de dados MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=sisgeri
DB_PASSWORD=sisgeri123
DB_NAME=sisgeri

# Sessão (use uma string longa e aleatória em produção)
SESSION_SECRET=troque_por_uma_string_secreta_longa

# E-mail (SMTP)
# Exemplo Gmail: habilite "Senhas de app" em Conta Google > Segurança
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seuemail@gmail.com
SMTP_PASS=sua_senha_de_app
SMTP_FROM=SISGERI <noreply@ic.ufmt.br>

# URL base da aplicação (usado nos links de e-mail)
APP_URL=http://localhost:3000