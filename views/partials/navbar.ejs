<% if (usuario) { %>
<nav class="navbar navbar-expand-lg navbar-light navbar-azul shadow-sm">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/dashboard">
            <i class="bi bi-key-fill me-1"></i>SISGERI
        </a>
        <button class="navbar-toggler" type="button"
                data-bs-toggle="collapse" data-bs-target="#navMenu"
                aria-controls="navMenu" aria-expanded="false">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navMenu">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                <!-- Reservas (todos os perfis) -->
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                        <i class="bi bi-calendar-plus"></i> Reservas
                    </a>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="/reservas"><i class="bi bi-list-ul me-1"></i>Minhas reservas</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item" href="/reservas/nova-ambiente"><i class="bi bi-door-open me-1"></i>Reservar ambiente</a></li>
                        <li><a class="dropdown-item" href="/reservas/nova-equipamento"><i class="bi bi-display me-1"></i>Reservar equipamento</a></li>
                    </ul>
                </li>

                <!-- Secretaria (funcionario + gestor) -->
                <% if (usuario.perfil === 'funcionario' || usuario.perfil === 'gestor') { %>
                <li class="nav-item">
                    <a class="nav-link" href="/chaves">
                        <i class="bi bi-key"></i> Chaves
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/equipamentos/movimentacoes">
                        <i class="bi bi-box-seam"></i> Empréstimos
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/atrasos">
                        <i class="bi bi-clock-history"></i> Atrasos
                    </a>
                </li>
                <% } %>

                <!-- Gestor -->
                <% if (usuario.perfil === 'gestor') { %>
                <li class="nav-item">
                    <a class="nav-link" href="/relatorios">
                        <i class="bi bi-bar-chart-line"></i> Relatórios
                    </a>
                </li>
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                        <i class="bi bi-gear"></i> Admin
                    </a>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="/admin/usuarios"><i class="bi bi-people me-1"></i>Usuários</a></li>
                        <li><a class="dropdown-item" href="/admin/ambientes"><i class="bi bi-building me-1"></i>Ambientes</a></li>
                        <li><a class="dropdown-item" href="/admin/equipamentos"><i class="bi bi-cpu me-1"></i>Equipamentos</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item" href="/admin/configuracoes"><i class="bi bi-sliders me-1"></i>Configurações</a></li>
                    </ul>
                </li>
                <% } %>

            </ul>

            <ul class="navbar-nav align-items-center">
                <li class="nav-item me-3">
                    <span class="navbar-text fw-semibold" id="relogio-navbar" style="font-size:0.95rem; color:#1a1a1a;">
                        <i class="bi bi-clock me-1"></i><span id="hora-atual"></span>
                    </span>
                </li>
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                        <i class="bi bi-person-circle me-1"></i><%= usuario.nome.split(' ')[0] %>
                        <span class="badge ms-1 small" style="background-color:#1b5e8c; color:#fff;"><%= usuario.perfil %></span>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><span class="dropdown-item-text text-muted small"><%= usuario.email || '' %></span></li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <a class="dropdown-item text-danger" href="/logout">
                                <i class="bi bi-box-arrow-right me-1"></i>Sair
                            </a>
                        </li>
                    </ul>
                </li>
            </ul>
        </div>
    </div>
</nav>
<script>
(function () {
    function atualizarHora() {
        const agora = new Date();
        document.getElementById('hora-atual').textContent =
            agora.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
    }
    atualizarHora();
    setInterval(atualizarHora, 1000);
})();
</script>
<% } %>