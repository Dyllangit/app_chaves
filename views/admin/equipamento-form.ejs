<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><%= equipamento ? 'Editar equipamento' : 'Novo equipamento' %></h4>
    <a href="/admin/equipamentos" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Voltar
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-4">
        <form method="POST" action="/admin/equipamentos/<%= equipamento ? equipamento.id + '/editar' : 'novo' %>">
            <div class="row g-3">
                <div class="col-md-5">
                    <label class="form-label">Nome *</label>
                    <input type="text" class="form-control" name="nome"
                           value="<%= equipamento ? equipamento.nome : '' %>" required>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Categoria *</label>
                    <input type="text" class="form-control" name="categoria"
                           value="<%= equipamento ? equipamento.categoria : '' %>"
                           placeholder="Projetor, Notebook…" required>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Código patrimonial</label>
                    <input type="text" class="form-control" name="codigo_patrimonio"
                           value="<%= equipamento ? (equipamento.codigo_patrimonio || '') : '' %>">
                </div>
                <% if (equipamento) { %>
                <div class="col-md-4">
                    <label class="form-label">Status</label>
                    <select class="form-select" name="status">
                        <% ['disponivel','em_manutencao','desativado'].forEach(s => { %>
                        <option value="<%= s %>" <%= equipamento.status === s ? 'selected' : '' %>><%= s.replace(/_/g,' ') %></option>
                        <% }) %>
                    </select>
                </div>
                <% } %>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-floppy me-1"></i>Salvar
                </button>
            </div>
        </form>
    </div>
</div>