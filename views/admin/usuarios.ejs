<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">Usuários</h4>
    <a href="/admin/usuarios/novo" class="btn btn-primary">
        <i class="bi bi-person-plus me-1"></i>Novo usuário
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Nome</th><th>E-mail</th><th>Matrícula</th><th>Cargo</th><th>Perfil</th><th>Ativo</th><th></th>
                </tr>
            </thead>
            <tbody>
                <% usuarios.forEach(u => { %>
                <tr class="<%= !u.ativo ? 'text-muted' : '' %>">
                    <td><%= u.nome %></td>
                    <td><%= u.email %></td>
                    <td><%= u.matricula || '—' %></td>
                    <td><%= u.cargo || '—' %></td>
                    <td><span class="badge bg-secondary"><%= u.perfil %></span></td>
                    <td>
                        <span class="badge <%= u.ativo ? 'bg-success' : 'bg-danger' %>">
                            <%= u.ativo ? 'Sim' : 'Não' %>
                        </span>
                    </td>
                    <td class="text-end">
                        <a href="/admin/usuarios/<%= u.id %>/editar" class="btn btn-sm btn-outline-secondary me-1">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <form method="POST" action="/admin/usuarios/<%= u.id %>/toggle-ativo" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-<%= u.ativo ? 'danger' : 'success' %>">
                                <i class="bi bi-<%= u.ativo ? 'person-x' : 'person-check' %>"></i>
                            </button>
                        </form>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>