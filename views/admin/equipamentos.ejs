<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">Equipamentos</h4>
    <a href="/admin/equipamentos/novo" class="btn btn-primary">
        <i class="bi bi-cpu me-1"></i>Novo equipamento
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr><th>Nome</th><th>Categoria</th><th>Patrimônio</th><th>Status</th><th></th></tr>
            </thead>
            <tbody>
                <% equipamentos.forEach(e => { %>
                <tr>
                    <td><%= e.nome %></td>
                    <td><%= e.categoria %></td>
                    <td><%= e.codigo_patrimonio || '—' %></td>
                    <td>
                        <span class="badge <%=
                            e.status === 'disponivel'    ? 'bg-success' :
                            e.status === 'em_manutencao' ? 'bg-warning text-dark' : 'bg-secondary'
                        %>">
                            <%= e.status.replace(/_/g,' ') %>
                        </span>
                    </td>
                    <td class="text-end">
                        <a href="/admin/equipamentos/<%= e.id %>/editar" class="btn btn-sm btn-outline-secondary">
                            <i class="bi bi-pencil"></i>
                        </a>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>