<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><%= usuario ? 'Editar usuário' : 'Novo usuário' %></h4>
    <a href="/admin/usuarios" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Voltar
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-4">
        <form method="POST" action="/admin/usuarios/<%= usuario ? usuario.id + '/editar' : 'novo' %>">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Nome completo *</label>
                    <input type="text" class="form-control" name="nome"
                           value="<%= usuario ? usuario.nome : '' %>" required>
                </div>
                <div class="col-md-6">
                    <label class="form-label">E-mail *</label>
                    <input type="email" class="form-control" name="email"
                           value="<%= usuario ? usuario.email : '' %>" required>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Matrícula</label>
                    <input type="text" class="form-control" name="matricula"
                           value="<%= usuario ? (usuario.matricula || '') : '' %>">
                </div>
                <div class="col-md-4">
                    <label class="form-label">CPF</label>
                    <input type="text" class="form-control" name="cpf"
                           value="<%= usuario ? (usuario.cpf || '') : '' %>">
                </div>
                <div class="col-md-4">
                    <label class="form-label">Cargo</label>
                    <input type="text" class="form-control" name="cargo"
                           value="<%= usuario ? (usuario.cargo || '') : '' %>">
                </div>
                <div class="col-md-4">
                    <label class="form-label">Perfil *</label>
                    <select class="form-select" name="perfil" required>
                        <% ['usuario','funcionario','gestor'].forEach(p => { %>
                        <option value="<%= p %>" <%= usuario && usuario.perfil === p ? 'selected' : '' %>><%= p %></option>
                        <% }) %>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Senha <%= usuario ? '(deixe vazio para manter)' : '*' %></label>
                    <input type="password" class="form-control" name="senha"
                           <%= usuario ? '' : 'required' %> autocomplete="new-password">
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-floppy me-1"></i>Salvar
                </button>
            </div>
        </form>
    </div>
</div>