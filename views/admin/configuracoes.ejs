<h4 class="mb-4">Configurações do sistema</h4>

<div class="card border-0 shadow-sm">
    <div class="card-body p-4">
        <form method="POST" action="/admin/configuracoes">
            <div class="table-responsive mb-4">
                <table class="table mb-0">
                    <thead class="table-light">
                        <tr><th>Parâmetro</th><th>Descrição</th><th>Valor</th></tr>
                    </thead>
                    <tbody>
                        <% configs.forEach(c => { %>
                        <tr>
                            <td><code><%= c.chave %></code><input type="hidden" name="chave" value="<%= c.chave %>"></td>
                            <td class="text-muted small"><%= c.descricao || '' %></td>
                            <td>
                                <input type="text" class="form-control form-control-sm" name="valor"
                                       value="<%= c.valor %>" style="max-width:150px">
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-floppy me-1"></i>Salvar configurações
            </button>
        </form>
    </div>
</div>