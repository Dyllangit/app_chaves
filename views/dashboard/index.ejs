<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0">Olá, <%= usuario.nome.split(' ')[0] %>!</h4>
        <small class="text-muted">Instituto de Computação — UFMT</small>
    </div>
</div>

<div class="row g-3">
    <!-- Card: Reservar ambiente -->
    <div class="col-sm-6 col-lg-3">
        <a href="/reservas/nova-ambiente" class="text-decoration-none">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center py-4">
                    <i class="bi bi-door-open display-5 text-primary"></i>
                    <p class="mt-2 mb-0 fw-semibold">Reservar ambiente</p>
                </div>
            </div>
        </a>
    </div>

    <!-- Card: Reservar equipamento -->
    <div class="col-sm-6 col-lg-3">
        <a href="/reservas/nova-equipamento" class="text-decoration-none">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center py-4">
                    <i class="bi bi-display display-5 text-primary"></i>
                    <p class="mt-2 mb-0 fw-semibold">Reservar equipamento</p>
                </div>
            </div>
        </a>
    </div>

    <!-- Card: Minhas reservas -->
    <div class="col-sm-6 col-lg-3">
        <a href="/reservas" class="text-decoration-none">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center py-4">
                    <i class="bi bi-calendar3 display-5 text-secondary"></i>
                    <p class="mt-2 mb-0 fw-semibold">Minhas reservas</p>
                </div>
            </div>
        </a>
    </div>

    <% if (usuario.perfil === 'funcionario' || usuario.perfil === 'gestor') { %>
    <!-- Card: Devoluções em atraso -->
    <div class="col-sm-6 col-lg-3">
        <a href="/atrasos" class="text-decoration-none">
            <div class="card border-0 shadow-sm border-start border-danger border-3 h-100">
                <div class="card-body text-center py-4">
                    <i class="bi bi-clock-history display-5 text-danger"></i>
                    <p class="mt-2 mb-0 fw-semibold">Devoluções em atraso</p>
                </div>
            </div>
        </a>
    </div>
    <% } %>
</div>