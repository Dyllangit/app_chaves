<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">Reserva #<%= reserva.id %></h4>
    <a href="/reservas" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Voltar
    </a>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <h6 class="card-title text-muted mb-3">Informações gerais</h6>
                <dl class="row mb-0">
                    <dt class="col-5">Solicitante</dt>
                    <dd class="col-7"><%= reserva.pessoa_nome %></dd>
                    <dt class="col-5">Data</dt>
                    <dd class="col-7"><%= new Date(reserva.data).toLocaleDateString('pt-BR') %></dd>
                    <dt class="col-5">Horário</dt>
                    <dd class="col-7"><%= reserva.horario_inicio.slice(0,5) %> – <%= reserva.horario_fim.slice(0,5) %></dd>
                    <dt class="col-5">Status</dt>
                    <dd class="col-7">
                        <span class="badge <%= reserva.status === 'confirmada' ? 'bg-success' : 'bg-secondary' %>">
                            <%= reserva.status %>
                        </span>
                    </dd>
                </dl>
            </div>
        </div>
    </div>

    <% if (ambientes && ambientes.length > 0) { %>
    <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <h6 class="card-title text-muted mb-3">Ambientes</h6>
                <% ambientes.forEach(a => { %>
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <div>
                        <strong><%= a.ambiente_nome %></strong><br>
                        <small class="text-muted">Chave: <%= a.chave_codigo || 'não cadastrada' %></small>
                    </div>
                    <span class="badge bg-info text-dark"><%= a.status.replace(/_/g,' ') %></span>
                </div>
                <% }) %>
            </div>
        </div>
    </div>
    <% } %>

    <% if (equipamentos && equipamentos.length > 0) { %>
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h6 class="card-title text-muted mb-3">Equipamentos</h6>
                <ul class="list-group list-group-flush">
                    <% equipamentos.forEach(e => { %>
                    <li class="list-group-item px-0 d-flex justify-content-between">
                        <div>
                            <strong><%= e.equipamento_nome %></strong>
                            <small class="text-muted ms-2"><%= e.categoria %></small>
                        </div>
                        <span class="badge bg-info text-dark"><%= e.status.replace(/_/g,' ') %></span>
                    </li>
                    <% }) %>
                </ul>
            </div>
        </div>
    </div>
    <% } %>
</div>

<% if (reserva.status === 'confirmada') { %>
<div class="mt-4">
    <form method="POST" action="/reservas/<%= reserva.id %>/cancelar"
          onsubmit="return confirm('Cancelar esta reserva?')">
        <button type="submit" class="btn btn-outline-danger btn-sm">
            <i class="bi bi-x-circle me-1"></i>Cancelar reserva
        </button>
    </form>
</div>
<% } %>