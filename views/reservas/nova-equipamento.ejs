<h4 class="mb-4">Reservar equipamento</h4>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <h6 class="card-title mb-3">1. Selecione data e horário</h6>
        <form method="POST" action="/reservas/buscar-equipamentos" class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Data</label>
                <input type="date" class="form-control" name="data"
                       value="<%= typeof data !== 'undefined' ? data : '' %>"
                       min="<%= new Date().toISOString().split('T')[0] %>" required>
            </div>
            <div class="col-md-3">
                <label class="form-label">Início</label>
                <input type="time" class="form-control" name="horario_inicio"
                       value="<%= typeof horario_inicio !== 'undefined' ? horario_inicio : '' %>" required>
            </div>
            <div class="col-md-3">
                <label class="form-label">Fim</label>
                <input type="time" class="form-control" name="horario_fim"
                       value="<%= typeof horario_fim !== 'undefined' ? horario_fim : '' %>" required>
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-outline-primary w-100">
                    <i class="bi bi-search"></i> Buscar
                </button>
            </div>
        </form>
    </div>
</div>

<% if (typeof equipamentos !== 'undefined' && equipamentos.length > 0) { %>
<div class="card border-0 shadow-sm">
    <div class="card-body">
        <h6 class="card-title mb-3">2. Selecione os equipamentos <small class="text-muted fw-normal">(pode escolher mais de um)</small></h6>
        <form method="POST" action="/reservas/nova-equipamento">
            <input type="hidden" name="data"           value="<%= data %>">
            <input type="hidden" name="horario_inicio" value="<%= horario_inicio %>">
            <input type="hidden" name="horario_fim"    value="<%= horario_fim %>">

            <div class="row g-3 mb-4">
                <% equipamentos.forEach(e => { %>
                <div class="col-md-4">
                    <div class="form-check card p-3 h-100">
                        <input class="form-check-input" type="checkbox"
                               name="equipamentos_ids" id="eq_<%= e.id %>" value="<%= e.id %>">
                        <label class="form-check-label w-100" for="eq_<%= e.id %>">
                            <strong><%= e.nome %></strong><br>
                            <small class="text-muted"><%= e.categoria %>
                                <% if (e.codigo_patrimonio) { %> · <%= e.codigo_patrimonio %><% } %>
                            </small>
                        </label>
                    </div>
                </div>
                <% }) %>
            </div>

            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-circle me-1"></i>Confirmar reserva
            </button>
        </form>
    </div>
</div>
<% } else if (typeof equipamentos !== 'undefined' && equipamentos.length === 0) { %>
<div class="alert alert-warning">
    <i class="bi bi-exclamation-triangle me-2"></i>
    Nenhum equipamento disponível para o horário selecionado.
</div>
<% } %>