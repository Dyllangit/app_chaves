<div class="card shadow border-0">
    <div class="card-body p-4 p-md-5">
        <div class="text-center mb-4">
            <i class="bi bi-envelope-open text-primary display-5"></i>
            <h5 class="fw-bold mt-2">Recuperar senha</h5>
            <small class="text-muted">Informe o e-mail cadastrado no sistema</small>
        </div>

        <form method="POST" action="/esqueci-senha" novalidate>
            <div class="mb-4">
                <label for="email" class="form-label">E-mail</label>
                <input type="email" class="form-control" id="email" name="email" required autofocus>
            </div>
            <div class="d-grid mb-3">
                <button type="submit" class="btn btn-primary">Enviar link de redefinição</button>
            </div>
            <div class="text-center">
                <a href="/login" class="text-decoration-none small text-muted">
                    <i class="bi bi-arrow-left me-1"></i>Voltar ao login
                </a>
            </div>
        </form>
    </div>
</div>