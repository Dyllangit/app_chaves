<div class="card shadow border-0">
    <div class="card-body p-4 p-md-5">
        <div class="text-center mb-4">
            <i class="bi bi-key-fill text-primary display-5"></i>
            <h4 class="fw-bold mt-2">SISGERI</h4>
            <small class="text-muted">Instituto de Computação — UFMT</small>
        </div>

        <form method="POST" action="/login" novalidate>
            <div class="mb-3">
                <label for="email" class="form-label">E-mail</label>
                <input type="email" class="form-control" id="email" name="email"
                       autocomplete="email" required autofocus>
            </div>
            <div class="mb-4">
                <label for="senha" class="form-label">Senha</label>
                <input type="password" class="form-control" id="senha" name="senha"
                       autocomplete="current-password" required>
            </div>
            <div class="d-grid mb-3">
                <button type="submit" class="btn btn-primary btn-lg">Entrar</button>
            </div>
            <div class="text-center">
                <a href="/esqueci-senha" class="text-decoration-none small text-muted">
                    Esqueci minha senha
                </a>
            </div>
        </form>
    </div>
</div>